{
  "name": "renanverse",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:twitter": "npm run dev -w apps/twitter",
    "dev:instagram": "npm run dev -w apps/instagram",
    "dev:reddit": "npm run dev -w apps/reddit",
    "dev:superpeer": "npm run dev -w apps/superpeer",
    "build": "npm run build -w packages/core && npm run build --workspaces --if-present",
    "smoke": "node scripts/smoke.mjs",
    "interop": "node scripts/interop.mjs",
    "test": "npm run smoke && npm run interop"
  },
  "devDependencies": {
    "socket.io-client": "^4.7.5",
    "tsx": "^4.16.2"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "better-sqlite3@12.11.1": true
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
